# Пример переменных окружения. Скопируй в .env (локально) или задай в UI хостинга.
# НИКОГДА не коммить реальные значения — .env в .gitignore.

# Telegram-бот (обязательно для bot.py)
TELEGRAM_BOT_TOKEN=
# chat id для рассылки из CLI (--telegram). Боту не нужен: он берёт chat из входящего сообщения.
TELEGRAM_CHAT_ID=

# Бесплатный LLM через OpenRouter (необязательно; без ключа — rule-based fallback)
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Несколько бесплатных моделей через запятую — перебираются по очереди при 429.
AGENT_LLM_MODEL=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free

# Каталог данных (анкеты, подписки). На хостинге укажи сюда путь смонтированного
# тома (volume), чтобы данные переживали редеплой. Локально можно не задавать.
AGENT_DATA_DIR=data

# Ежедневный дайджест подписчикам:
#   AGENT_DIGEST_INTERVAL_SEC — как часто слать одному подписчику (по умолч. 86400 = раз в день)
#   AGENT_DIGEST_TICK_SEC     — как часто воркер проверяет очередь (по умолч. 900 = 15 мин)
AGENT_DIGEST_INTERVAL_SEC=86400
AGENT_DIGEST_TICK_SEC=900
